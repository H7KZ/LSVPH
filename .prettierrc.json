{
	"$schema": "https://json.schemastore.org/prettierrc",
	"useTabs": true,
	"tabWidth": 4,
	"semi": false,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 160,
	"quoteProps": "as-needed",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "avoid",
	"plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
	"importOrder": [
		"<TYPES>",
		"^vue$",
		"^vue-(.*)$",
		"^@vue/(.*)$",
		"^@vueuse/(.*)$",
		"^pinia$",
		"^@unhead/(.*)$",
		"<THIRD_PARTY_MODULES>",
		"^@shared/(.*)$",
		"^@api/(.*)$",
		"^@client/(.*)$",
		"^~icons/(.*)$",
		"^[./]"
	],
	"importOrderTypeScriptVersion": "5.0.0"
}
